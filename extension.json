{
	"name": "AknRenderer",
	"namemsg": "aknrenderer-extensionname",
	"version": "0.1.0",
	"author": [
		"Dimitrys"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:AknRenderer",
	"descriptionmsg": "aknrenderer-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"platform": {
			"php": ">= 8.1"
		}
	},
	"namespaces": [
		{
			"id": 3000,
			"constant": "NS_LAW",
			"name": "Law",
			"subpages": false,
			"content": true,
			"defaultcontentmodel": "akn-xml"
		},
		{
			"id": 3001,
			"constant": "NS_LAW_TALK",
			"name": "Law_talk",
			"subpages": true,
			"content": false,
			"defaultcontentmodel": "wikitext"
		},
		{
			"id": 3002,
			"constant": "NS_GAZETTE",
			"name": "Gazette",
			"subpages": false,
			"content": true,
			"defaultcontentmodel": "akn-xml"
		},
		{
			"id": 3003,
			"constant": "NS_GAZETTE_TALK",
			"name": "Gazette_talk",
			"subpages": true,
			"content": false,
			"defaultcontentmodel": "wikitext"
		}
	],
	"ContentHandlers": {
		"akn-xml": "MediaWiki\\Extension\\AknRenderer\\AknContentHandler"
	},
	"Actions": {
		"revisions": "MediaWiki\\Extension\\AknRenderer\\AknRevisionsAction"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\AknRenderer\\": "includes/",
		"MediaWiki\\Extension\\AknRenderer\\Maintenance\\": "maintenance/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Extension\\AknRenderer\\Tests\\Unit\\": "tests/phpunit/unit/"
	},
	"MessagesDirs": {
		"AknRenderer": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"AknRendererNamespaces": "AknRenderer.namespaces.php"
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "AknRenderer/resources"
	},
	"ResourceModules": {
		"ext.aknRenderer.styles": {
			"styles": "ext.aknRenderer.styles.css"
		},
		"ext.aknRenderer.targetFlash": {
			"scripts": "ext.aknRenderer.targetFlash.js"
		}
	},
	"APIModules": {
		"aknreference": {
			"class": "MediaWiki\\Extension\\AknRenderer\\ApiAknReference",
			"services": [
				"ConnectionProvider"
			]
		}
	},
	"HookHandlers": {
		"main": {
			"class": "MediaWiki\\Extension\\AknRenderer\\HookHandler",
			"services": [
				"ConnectionProvider",
				"WikiPageFactory"
			]
		},
		"schema": {
			"class": "MediaWiki\\Extension\\AknRenderer\\SchemaHooks"
		}
	},
	"Hooks": {
		"InfoAction": "main",
		"SkinTemplateNavigation::Universal": "main",
		"PageSaveComplete": "main",
		"PageDeleteComplete": "main",
		"ResourceLoaderGetConfigVars": "main",
		"LoadExtensionSchemaUpdates": "schema"
	},
	"callback": "MediaWiki\\Extension\\AknRenderer\\Hooks::onRegistration",
	"manifest_version": 2
}
